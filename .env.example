# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is committed as a template.

# ---------------------------------------------------------------------------
# Database (PostgreSQL via Supabase)
# ---------------------------------------------------------------------------
# Get these from your Supabase project's "Connect" panel:
#   https://supabase.com/dashboard -> Project -> Connect -> ORMs -> Prisma
#
# For Phase 2 you only need DATABASE_URL — set it to the *direct* connection
# string (port 5432, NOT 6543). PgBouncer's transaction pooler can break
# Prisma migrations and long-running bulk inserts.
#
# DIRECT_URL is optional today. When we deploy to Vercel in Phase 6 we'll
# flip DATABASE_URL to the pooled (port 6543) string for the serverless app
# runtime, and DIRECT_URL will hold the direct (5432) string for the Python
# ingestion job + Prisma migrations.
#
# Example (Supabase direct):
#   DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres"

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
